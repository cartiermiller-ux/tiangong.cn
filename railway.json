{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "server/**",
      "railway-start.sh",
      "railway.json"
    ],
    "buildCommand": "cd server && npm install"
  },
  "deploy": {
    "startCommand": "bash railway-start.sh",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheck": {
      "path": "/api/health",
      "timeout": 300
    }
  },
  "volumes": [
    {
      "mountPath": "/data"
    }
  ]
}