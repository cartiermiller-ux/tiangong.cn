# ========== 服务器配置 ==========
PORT=3000
NODE_ENV=production

# JWT 密钥（请改为随机长字符串）
JWT_SECRET=change_this_to_a_random_long_string_at_least_32_chars

# 前端地址（CORS 白名单）
FRONTEND_URL=https://skyagent-artifacts.tiangong.cn

# ========== 数据库 ==========
DB_PATH=./data/shop.db

# ========== 邮件服务（SMTP）==========
# 方式 A：直接在后台「系统设置 → 邮件服务」填写（保存到 settings 表，无需重启）
# 方式 B：写在 .env 文件（仅作为首次启动的默认值，UI 保存后会覆盖）
#
# Gmail 配置步骤：
#   1. 登录 Google 账号 → https://myaccount.google.com/security
#   2. 开启「2-Step Verification」（2步验证）
#   3. 进入「App passwords」（应用密码）→ 选择「Mail」→ 生成 16 位应用密码
#   4. 将 16 位密码填入下方 SMTP_PASS（空格无所谓，系统会自动去除）
#   5. 如账户有 Workspace，确保管理员允许 SMTP 访问
#
# 注：QQ 邮箱用 smtp.qq.com / 465，授权码在 QQ 邮箱设置里开启
# 网易 163 用 smtp.163.com / 465，授权码在邮箱设置里开启
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=yourname@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=阿凡达在海上 <yourname@gmail.com>

# ========== 支付宝当面付 ==========
# 在 https://open.alipay.com 创建应用获取
ALIPAY_APP_ID=2021000000000000
# 应用私钥（PKCS8 格式，不含 BEGIN/END 标记）
ALIPAY_APP_PRIVATE_KEY=your_app_private_key
# 支付宝公钥
ALIPAY_ALIPAY_PUBLIC_KEY=your_alipay_public_key
# 支付回调地址（部署后改为你的实际域名）
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/alipay/notify
# 沙箱模式设为 true，正式环境设为 false
ALIPAY_SANDBOX=false

# ========== 管理员初始账号 ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@example.com
